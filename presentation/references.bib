	abstract = {Hoeffding's lemma gives an integral representation of the covariance of two random variables in terms of the difference between their joint and marginal probability functions, i.e., \${\textbackslash}operatorname\{cov\}(X, Y) = {\textbackslash}int{\textasciicircum}{\textbackslash}infty\_\{-{\textbackslash}infty\} {\textbackslash}int{\textasciicircum}{\textbackslash}infty\_\{-{\textbackslash}infty\} {\textbackslash}\{P(X {\textgreater} x, Y {\textgreater} y) - P(X {\textgreater} x)P(Y {\textgreater} y){\textbackslash}\} dx dy.\$ This identity has been found to be a useful tool in studying the dependence structure of various random vectors. A generalization of this result for more than two random variables is given. This involves an integral representation of the multivariate joint cumulant. Applications of this include characterizations of independence. Relationships with various types of dependence are also given.},
	language = {en},
	number = {4},
	urldate = {2026-03-08},
	journal = {The Annals of Probability},
	publisher = {Institute of Mathematical Statistics},
	author = {Block, Henry W. and Fang, Zhaoben},
	month = oct,
	year = {1988},
	keywords = {60E05, 62H05, Hoeffding's lemma, Positive dependence, association, characterization of independence, inequalities for characteristic functions, joint cumulant},
